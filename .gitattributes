data/raw/** filter=lfs diff=lfs merge=lfs -text
data/external/** filter=lfs diff=lfs merge=lfs -text
data/processed/** filter=lfs diff=lfs merge=lfs -text
data/analysis/** filter=lfs diff=lfs merge=lfs -text

# Figure-reproduction gist scripts + gist-context markdown ship as
# plain git, not LFS — they're tiny (1–13 KB each) and CI needs to
# read their contents directly (tests/test_figure_gists_styling.py
# greps each script for the brand-style sentinel + palette anchors;
# an LFS pointer there fails every assertion). The PNG / PDF figure
# outputs alongside them stay LFS-tracked under the general rule above.
data/analysis/figures/*.py -filter -diff -merge text
data/analysis/figures/*.md -filter -diff -merge text

# Small reference TSVs that ship as plain git so a fresh `git clone`
# can run the genome-wide sweeps without an LFS-hydration step. The
# 3.4 MB upstream NCBI protein-coding catalog is the canonical input
# for the 19,464-gene sweep; the M1-subtracted view is computed from
# it. Both well below GitHub's 50 MB soft limit.
data/external/ncbi_gene_info/Homo_sapiens.protein_coding.with_hgnc.tsv -filter -diff -merge text
data/external/ncbi_gene_info/Homo_sapiens.protein_coding.with_hgnc.cleaned.tsv -filter -diff -merge text
data/external/ncbi_gene_info/Homo_sapiens.protein_coding.with_hgnc.resolvable.tsv -filter -diff -merge text
data/external/ncbi_gene_info/Homo_sapiens.protein_coding.with_hgnc.triageable.tsv -filter -diff -merge text

# Candidate-universe TSV is small (~1.4 MB) and the canonical data
# source for figure-reproduction gists linked from blog posts; ship
# as plain git so raw.githubusercontent.com can serve the file
# content directly (LFS pointers don't resolve over the raw URL).
data/processed/candidate_universe/candidate_universe.tsv -filter -diff -merge text
data/processed/candidate_universe/candidate_universe_v2.tsv -filter -diff -merge text

# Canonical main-bench export (D1 → flat TSV) — same role as the
# candidate-universe TSVs above: drives gist-style reproduction
# scripts under data/analysis/figures/. ~160 KB.
data/processed/triage_bench/mainbench_canonical_v1.tsv -filter -diff -merge text

