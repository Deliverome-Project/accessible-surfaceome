# accessible-surfaceome environment template.
#
# Copy or symlink this to .env at the repo root and fill in your keys:
#
#   cp .env.example .env
#
# .env is gitignored. Never commit real keys. For shared dev setups, see the
# ACCESSIBLE_SURFACEOME_ENV_SOURCE / scripts/bootstrap-worktree.sh convention
# documented in AGENTS.md.
#
# Variables already set in the shell take precedence over this file — CI and
# `export FOO=...` always win.

# Anthropic API key (used by the surface-annotator Managed Agent).
# Required for: `accessible-surfaceome agents sync`
#                `accessible-surfaceome agents annotate <gene>`
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# NCBI E-utilities API key (optional but strongly recommended).
# Without it: gene_lookup runs at NCBI's unauthenticated 3 qps cap.
# With it:    raised to 10 qps, with our internal limiter at ~9 qps.
# Get one at: https://www.ncbi.nlm.nih.gov/account/settings/  → API Key Management
NCBI_API_KEY=
