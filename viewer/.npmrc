; npm install hardening — viewer project
; Following lirantal/npm-security-best-practices.
;
; engine-strict     Enforce the `engines.node` field instead of warning, so
;                   `npm install` refuses to run on the wrong Node major.
;
; audit-level=high  Make `npm audit` (and the implicit audit during install)
;                   exit non-zero on high or critical advisories. CI also
;                   runs `npm audit --audit-level=high` explicitly.
;
; min-release-age=7 Quarantine: refuse to install package versions published
;                   less than 7 days ago. Defense against fresh supply-chain
;                   attacks (e.g. Mini Shai-Hulud, 2026-05-12) where the
;                   malicious version is yanked within hours but anyone who
;                   resolved in the window is compromised.
;
;                   *Caveat*: as of npm 11.11.0 this config is defined but
;                   not yet wired into resolution — `npm config get
;                   min-release-age` returns the value, but `npm install`
;                   doesn't actually filter by it. We keep it here so the
;                   defense activates automatically once npm completes the
;                   wiring (likely 11.12+).
;
;                   For new dep additions today, use `npm run safe-add
;                   <package>` instead of `npm install <package>` — that
;                   script invokes the working `--before` flag with a
;                   rolling 7-day cutoff. `npm ci` against an already-pinned
;                   lockfile is unaffected by either setting; the lockfile
;                   + integrity SHAs are the primary defense for CI.

engine-strict=true
audit-level=high
min-release-age=7
