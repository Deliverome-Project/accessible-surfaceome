# Cloudflare Worker that serves the public read-only Surfaceome API.
#
# Template — copy to `wrangler.toml` and fill in `database_id` below.
# The real `wrangler.toml` is gitignored so the public D1 UUID stays
# out of the public repo. Bootstrap one of two ways:
#
#   # 1. Manual:
#   cp wrangler.toml.example wrangler.toml
#   # then edit database_id to your CLOUDFLARE_D1_SURFACEOME_PUBLIC_ID
#
#   # 2. From your .env (loads CLOUDFLARE_D1_SURFACEOME_PUBLIC_ID):
#   set -a; source ../../../.env; set +a
#   sed "s/REPLACE_WITH_PUBLIC_D1_UUID/${CLOUDFLARE_D1_SURFACEOME_PUBLIC_ID}/" \
#     wrangler.toml.example > wrangler.toml
#
# Reads from the `surfaceome_public` D1 database (the public mirror of
# `surfaceome_agents`). Designed to live under
# `api.deliverome.org/surfaceome/*` or as a Workers-route on the existing
# Pages project.

name = "surfaceome-api"
main = "src/index.js"
compatibility_date = "2026-05-01"

# `workers_dev = true` keeps the unbranded `<worker>.<subdomain>.workers.dev`
# URL alive as a fallback. Once the `api.deliverome.org/surfaceome/*` route is
# verified working, flip to `workers_dev = false` so the only public URL is
# the branded one.
workers_dev = true

# Read-only binding to the public D1 mirror. The Worker code reads
# `env.DB` and runs SQL against it. `wrangler deploy` parses
# `database_id` literally — there's no env-var interpolation for D1
# bindings, so the value must be substituted locally before deploy.
[[d1_databases]]
binding = "DB"
database_name = "surfaceome_public"
database_id = "REPLACE_WITH_PUBLIC_D1_UUID"

# Per-Worker observability: keep tail logs on so we can debug
# production cache misses / 5xx without re-deploying with a verbose flag.
[observability]
enabled = true

# Public route: path-routed under api.deliverome.org/surfaceome/*.
# `zone_name` is the *parent* Cloudflare zone (`deliverome.org`),
# NOT the route hostname — there is no separate Cloudflare zone for
# `api.deliverome.org`; it's a subdomain managed under the
# deliverome.org zone. (Wrangler's error message on this misnames
# the zone after the hostname; ignore that and use the parent.)
#
# The deploying API token needs `Zone → Workers Routes → Edit` on
# the deliverome.org zone; the account-level `Workers Scripts →
# Edit` (used for the upload above) does NOT cover zone-scoped
# route bindings. If the deploy errors with "does not have
# permission to access the zone ...", either grant that scope on
# the token or add the route once in the dashboard:
#   Workers & Pages → surfaceome-api → Settings → Triggers →
#   Routes → Add → "api.deliverome.org/surfaceome/*".
#
# `[[routes]]` (array-of-tables) rather than `routes = [...]` so
# linters that reflow inline arrays don't accidentally nest the key
# under a preceding `[section]` header.
[[routes]]
pattern = "api.deliverome.org/surfaceome/*"
zone_name = "deliverome.org"

# --- Per-IP rate limiting (Workers native Rate Limiting binding) ---
#
# In-colo, in-memory limiter — NOT KV: no per-request storage read/write
# and no storage cost, and it's free on every plan (this is the path when
# the zone doesn't have WAF Rate Limiting Rules, which need Pro+). The
# Worker calls `env.RATE_LIMITER.limit({ key })` and 429s on overflow; an
# absent binding (older wrangler / local dev) just skips the check.
#
# `namespace_id` is an arbitrary integer you pick (unique per account, no
# dashboard provisioning needed). `period` accepts only 10 or 60 seconds.
# Counting is per-datacenter, so a distributed attacker gets N×limit total
# — fine for bounding cost; Cloudflare's always-on L7 DDoS protection
# (free, automatic) covers the volumetric case underneath.
#
# Two limiters: a generous one for the whole route, and a tighter one for
# the CPU-heavy endpoints (/v1/catalog + the *.tsv exports).
[[unsafe.bindings]]
name = "RATE_LIMITER"
type = "ratelimit"
namespace_id = "1001"
simple = { limit = 600, period = 60 }   # 600 req / 60s / IP on the route

[[unsafe.bindings]]
name = "RATE_LIMITER_HEAVY"
type = "ratelimit"
namespace_id = "1002"
simple = { limit = 60, period = 60 }    # 60 req / 60s / IP on catalog + *.tsv

# --- Rich per-gene Markdown export (R2) ---
#
# Serves GET /v1/genes/{symbol}.md — the human-readable record bundle with
# reanalysis extras not in the JSON/D1 (canonical/isoform/ortholog
# sequences, DeepTMHMM topology, AlphaFold links). The .md files are
# generated offline and uploaded to this bucket by
# `viewer/scripts/build-markdown-exports.mjs` (R2 mode); the Worker only
# streams them back. Keyed `{HGNC_SYMBOL}.md`.
#
# Unlike D1, R2 bindings take a plain bucket_name (no secret UUID), so this
# is committed with real values. One-time provisioning before first deploy:
#   npx wrangler r2 bucket create surfaceome-gene-md
# then populate it (see the generator's R2 mode).
[[r2_buckets]]
binding = "GENE_MD"
bucket_name = "surfaceome-gene-md"

# --- Feedback flow bindings (per docs/superpowers/specs/2026-05-25-feedback-button-design.md) ---

# Write binding for unmoderated submissions (PII + audit). Same database
# as the main agent-run history. Used by:
#   POST /v1/feedback/submit   — INSERT a new submission row
#   GET  /v1/feedback/moderate — UPDATE the row's status on magic-link click
[[d1_databases]]
binding = "FEEDBACK_DB"
database_name = "surfaceome_agents"
database_id = "REPLACE_WITH_AGENTS_D1_UUID"

# Rate-limit counters (5 submissions / IP-hash / hour). Worker reads /
# writes a single per-hour-bucket counter; KV's eventual consistency is
# fine for this use (a burst of 6-10 once an hour is not a real DoS).
[[kv_namespaces]]
binding = "FEEDBACK_RATELIMIT"
id = "REPLACE_WITH_FEEDBACK_RATELIMIT_KV_ID"

# Secrets — set via:
#   cd cloudflare/workers/surfaceome_api
#   npx wrangler secret put RESEND_API_KEY
#   npx wrangler secret put TURNSTILE_SECRET_KEY
#   npx wrangler secret put MAGIC_LINK_SECRET
#   npx wrangler secret put MAINTAINER_EMAIL
# Values come from the root .env (RESEND_API_KEY, TURNSTILE_SECRET_KEY,
# MAGIC_LINK_SECRET, MAINTAINER_EMAIL respectively).
