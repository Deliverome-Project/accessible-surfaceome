{
  "name": "accessible-surfaceome-viewer",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "npm run build:exports && next build --webpack",
    "build:exports": "node scripts/build-markdown-exports.mjs",
    "start": "next start",
    "deploy": "wrangler pages deploy out",
    "check": "tsc --project tsconfig.json --noEmit",
    "safe-add": "npm install --before=\"$(date -u -v -7d +%Y-%m-%d)\""
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.24",
    "3dmol": "^2.5.4",
    "next": "16.3.0-canary.11",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "engines": {
    "node": "^24"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "typescript": "^5.8.2",
    "wrangler": "^4.6.0"
  }
}
