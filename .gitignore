# Python
__pycache__/
*.py[cod]

# Virtual env
.venv/

# Tool caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Claude Code local worktrees
.claude/worktrees/

# Claude Preview launch.json — per-worktree config for the local
# preview tool; not meant to be committed. The `.claude/` line above
# would catch it at the repo root, but worktrees have their own
# `.claude/` and the rule there needs to be explicit.
.claude/launch.json

# OS
.DS_Store

# Local secrets/runtime
.env
*.log

# Wrangler.toml for the public Worker carries the surfaceome_public D1 UUID
# inline (wrangler doesn't interpolate env vars into D1 bindings), so the
# real file is generated from wrangler.toml.example and gitignored. See
# cloudflare/workers/surfaceome_api/README.md.
cloudflare/workers/surfaceome_api/wrangler.toml

# Managed Agents run logs and tool cache (gitignored — contain timestamps,
# session IDs, and possibly upstream API responses)
.runs/
data/external/tool_cache.sqlite*
# Binary HTTP cache (CachedHTTP.get_bytes) — downloaded OA publisher PDFs for the
# triage Unpaywall fallback. Local cache only; never commit (copyright + bloat).
data/external/blob_cache/

# Per-gene annotations are agent-generated; commit a curated snapshot once
# we have a stable set, not every smoke-test output.
data/annotations/

# Per-gene triage records are also agent-generated; same reasoning.
data/triage/

# Bulk external data dropped from version control to keep Cloudflare Pages
# clones fast — every Pages build pulls all HEAD LFS objects, and these
# two dirs were ~2 GB on their own. Re-fetch locally with the matching
# downloader in `src/accessible_surfaceome/sources/`:
#   * DeepTMHMM academic-license zip — install via
#     `accessible-surfaceome tools deeptmhmm install` (signup-gated by
#     the upstream project; the install handler walks you through it).
#   * JensenLab COMPARTMENTS source TSVs — download via
#     `python -m accessible_surfaceome.sources.compartments download`.
data/external/deeptmhmm/
data/external/jensenlab_compartments/

# Triage-bench per-run records (one JSON per protein per cell). Reproducible
# from `accessible-surfaceome triage-bench run`. The benchmark TSV input
# lives at data/eval/triage_benchmark_v1.tsv and is committed.
data/eval/triage_bench_v1/

# `--smoke` runs of the sub-bench runner land here so a wiring test
# can't clobber canonical artifacts (see triage_subbench_runner.py's
# _smoke_routing). Throwaway by design — nuke with `rm -rf
# data/eval/_smoke/`.
data/eval/_smoke/

# Per-source corpus written by the orchestrator (raw + normalized text +
# citation metadata for every PMID/PMC/UniProt/WO the agent has fetched).
# Reproducible from the upstream sources; commit a curated baseline later.
data/sources/

# Node devDependencies. wrangler is pinned in /package.json (used by the
# cloudflare/ scripts for D1 / R2). The viewer SPA has its own
# package.json + node_modules under viewer/. Reproducible via `npm ci`.
node_modules/
viewer/node_modules/

# Local D1 → SQL dumps from `scripts/d1_export_to_r2.sh --keep-local`.
# The canonical copies live in R2 (deliverome-d1-backups). The local
# copies are convenience-only; reproducible from R2 at any time.
data/processed/cloudflare/d1_backups/

# Scratch dir scripts/release/publish-archive.py uses to stage
# API-fetched payloads + the deep-dives tarball before upload.
_extra-download/

# Per-run outputs from scripts/run_topology_sweep.py — topology JSONL,
# events log, and DeepTMHMM batch staging. Each ``topo_<version>`` dir is
# reproducible from candidate_universe.tsv + the legacy .3line + a fresh
# DeepTMHMM run. The TSVs / JSONLs uploaded to D1 are the canonical
# distribution channel.
data/processed/topology_run_*/
data/external/deeptmhmm_topology_run_*/

# Ensembl Compara paralog BioMart pull (raw + per-gene CSV). Reproducible
# from `python -m accessible_surfaceome.sources.ensembl_compara_paralogs
# download` — same lifecycle as the existing ensembl_compara ortholog pull.
data/external/ensembl_compara_paralogs/

# UniProt FASTA cache populated by scripts/run_topology_sweep.py. Each
# file is a single-protein FASTA at <acc>.fasta; reproducible from
# UniProt's REST endpoint and intentionally not version-controlled.
data/external/sequences/

# Ortholog Ensembl→UniProt resolution cache, written incrementally by
# scripts/run_topology_sweep.py during mouse + cyno ortholog stages.
# Idempotent re-generation; not version-controlled.
data/external/ortholog_uniprot_resolution.tsv

# Per-UniProt SURFACE-Bind summary — a 1.7MB derived artifact built by
# scripts/build_surface_bind_summary.py from the upstream SURFACE-Bind
# GitHub database (github.com/hamedkhakzad/SURFACE-Bind). The live site
# reads it from D1 (synced via scripts/sync_surface_bind_to_d1.py); the
# on-disk copy is a regenerable build input, so it's not version-controlled.
data/external/surface_bind/

# Claude Code dev-server preview config — local-only, not for the repo.
.claude/launch.json

# AFDB prediction cache (CIF structures + JSON metadata) — populated on
# demand by src/accessible_surfaceome/tools/afdb_plddt.py, idempotent from
# alphafold.ebi.ac.uk. The CIFs are 200KB-1.1MB each; the JSON metadata is
# ~3KB each. Both are a per-machine fetch cache that adds nothing reviewers
# can't re-fetch in seconds, so neither belongs in version control.
data/cache/afdb_prediction/*.cif
data/cache/afdb_prediction/*.json
