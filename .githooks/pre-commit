#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"

if command -v pre-commit >/dev/null 2>&1; then
  (cd "$repo_root" && pre-commit run --hook-stage pre-commit --config .pre-commit-config.yaml)
  exit 0
fi

if command -v uv >/dev/null 2>&1; then
  (cd "$repo_root" && uv run --project "$repo_root" pre-commit run --hook-stage pre-commit --config .pre-commit-config.yaml)
  exit 0
fi

echo "[hooks] pre-commit is not available; run 'uv sync'." >&2
exit 1
