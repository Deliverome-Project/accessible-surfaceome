# accessible-surfaceome environment template.
#
# Copy or symlink this to .env at the repo root and fill in your keys:
#
#   cp .env.example .env
#
# .env is gitignored. Never commit real keys. For shared dev setups, see the
# ACCESSIBLE_SURFACEOME_ENV_SOURCE / scripts/bootstrap-worktree.sh convention
# documented in AGENTS.md.
#
# Variables already set in the shell take precedence over this file — CI and
# `export FOO=...` always win.

# Anthropic API key (used by the surface-annotator Managed Agent).
# Required for: `accessible-surfaceome agents sync`
#                `accessible-surfaceome agents annotate <gene>`
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# NCBI E-utilities API key (optional but strongly recommended).
# Without it: gene_lookup runs at NCBI's unauthenticated 3 qps cap.
# With it:    raised to 10 qps, with our internal limiter at ~9 qps.
# Get one at: https://www.ncbi.nlm.nih.gov/account/settings/  → API Key Management
NCBI_API_KEY=

# --- Cloudflare D1: surfaceome_agents database -------------------------------
# Required for scripts/upload_triage_runs_to_d1.py and the
# accessible_surfaceome.cloud.* modules. See cloudflare/README.md for the
# one-time wrangler provisioning walkthrough.

# Account UUID — same hex that appears in the Cloudflare dashboard URL,
# e.g. dash.cloudflare.com/<this-hex>/pages/view/deliverome
CLOUDFLARE_ACCOUNT_ID=

# UUID returned by `wrangler d1 create surfaceome_agents` (one-time).
CLOUDFLARE_D1_SURFACEOME_AGENTS_ID=

# UUID of the public-mirror D1 (surfaceome_public). Required for
# scripts/sync_public_d1.py and scripts/upload_candidate_universe_to_d1.py.
# Also substituted into cloudflare/workers/surfaceome_api/wrangler.toml at
# deploy time — the committed wrangler.toml.example carries a placeholder,
# the real wrangler.toml is gitignored. Look the UUID up with
#   `wrangler d1 list`  or the dashboard's D1 page.
CLOUDFLARE_D1_SURFACEOME_PUBLIC_ID=

# API token scoped to D1:Edit on this account. Create at
# https://dash.cloudflare.com/profile/api-tokens → Custom token →
# permissions: Account > D1 > Edit, scoped to the deliverome account.
#
# For edge-cache purge-on-publish (cloud/surface_annotation.py) and the
# zone rulesets script (scripts/apply_cf_edge_rules.py) the SAME token also
# needs these ZONE-scoped permissions on the deliverome.org zone:
#   Zone > Cache Purge > Purge        (purge-on-publish)
#   Zone > Cache Rules > Edit         (apply_cf_edge_rules cache rule)
#   Zone > Rate Limiting Rules > Edit (apply_cf_edge_rules rate-limit rules)
# Missing scopes soft-skip with a warning — publish/D1 still works.
CLOUDFLARE_API_TOKEN=

# deliverome.org zone UUID (Cloudflare dashboard → the zone → Overview →
# API section, right column). Required for edge-cache purge-on-publish and
# scripts/apply_cf_edge_rules.py. Unset = purge is soft-skipped (records go
# live on the Worker's Cache-Control TTL instead of immediately).
CLOUDFLARE_ZONE_ID=
